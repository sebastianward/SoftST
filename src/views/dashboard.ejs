<%- include("partials/head", { title: "Panel" }) %>
<%- include("partials/header") %>

<main class="page-shell">
  <section class="hero">
    <div>
      <h1>Operacion de ingresos</h1>
      <p>Desde aqui puedes registrar nuevos ingresos, revisar historial y administrar trabajadores.</p>
    </div>
    <a class="button-link" href="/entries/new">Crear ingreso</a>
  </section>

  <section class="stats-grid">
    <article class="stat-card">
      <span>Trabajadores activos</span>
      <strong><%= stats.activeWorkers %></strong>
    </article>
    <article class="stat-card">
      <span>Ingresos acumulados</span>
      <strong><%= stats.totalEntries %></strong>
    </article>
    <article class="stat-card">
      <span>Notificaciones visibles</span>
      <strong><%= notificationCount %></strong>
    </article>
  </section>

  <section class="panel">
    <div class="panel-title">
      <h2>Ultimos ingresos</h2>
      <a href="/entries">Ver todo</a>
    </div>

    <% if (latestEntries.length === 0) { %>
      <p class="empty-state">Todavia no hay ingresos registrados.</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Empresa</th>
              <th>Equipo</th>
              <th>Ingresado por</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            <% latestEntries.forEach((entry) => { %>
              <tr>
                <td>#<%= entry.id %></td>
                <td><%= entry.business_name %></td>
                <td><%= entry.equipment_model %></td>
                <td><%= entry.worker_name_snapshot %></td>
                <td><%= entry.created_at %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</main>

<%- include("partials/foot") %>
